{
  "hooks": {
    "Setup": [
      {
        "matcher": "init",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/jira setup 2>&1",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "maintenance",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/jira setup 2>&1",
            "timeout": 120
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/jira start >/dev/null 2>&1 || ${CLAUDE_PLUGIN_ROOT}/bin/jira setup >/dev/null 2>&1 && ${CLAUDE_PLUGIN_ROOT}/bin/jira start >/dev/null 2>&1 || true",
            "async": true,
            "timeout": 120
          }
        ]
      }
    ]
  }
}
